# ============================================
# Vort MVP - Environment Variables Template
# ============================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is in .gitignore.
# ============================================

# --- Hiro API ---
# The base URL for the Hiro Stacks API.
# Testnet: https://api.testnet.hiro.so
# Mainnet: https://api.hiro.so
HIRO_API_URL=https://api.testnet.hiro.so

# --- Chainhook Webhook Security ---
# A shared secret used to verify incoming Chainhook webhook payloads via HMAC-SHA256.
# Generate a strong random value: openssl rand -hex 32
CHAINHOOK_AUTH_TOKEN=

# --- KV Store (Upstash Redis) ---
# For local development, leave these blank — the app falls back to an in-memory store.
# For production, create a free Upstash Redis database at https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Smart Contract Addresses ---
# The deployer address and contract identifiers on the target network.
NEXT_PUBLIC_NETWORK=testnet
NEXT_PUBLIC_CONTRACT_DEPLOYER=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM
NEXT_PUBLIC_TOKENIZER_CONTRACT=tokenizer
NEXT_PUBLIC_PT_AMM_CONTRACT=pt-amm
